# Groq API key. Get one free at https://console.groq.com.
# The free tier covers Llama 3.3 70B with daily token limits that comfortably
# fit personal use. AI routes degrade gracefully when this key is missing.
GROQ_API_KEY=

# Model id. Default: llama-3.3-70b-versatile.
GROQ_MODEL=llama-3.3-70b-versatile

# TMDB read access token (v3 API key works too).
# Free at https://www.themoviedb.org/settings/api. The app falls back to a
# limited demo mode when this is absent so you can still click around.
TMDB_API_KEY=

# Public base URL for share links and OG images. Optional in dev.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
